<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Bảng Điều Khiển - PKSoft Admin</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    
    <%- include('style') %>
</head>
<body>

    <%- include('navbar') %>

    <div class="dashboard-header shadow-sm">
        <div class="container d-flex justify-content-between align-items-center">
            <div>
                <h2 class="fw-bold mb-1">Bảng Điều Khiển</h2>
                <p class="text-muted mb-0">
                    Xin chào, <strong class="text-danger"><%= user ? user.hoTen : 'Quản Trị Viên' %></strong>! 
                    Bạn đang đăng nhập với vai trò: <span class="badge bg-dark"><%= user ? (user.vaiTro === 'QuanTriVien' ? 'Quản Trị Tối Cao' : 'Nhân Viên Sale') : 'N/A' %></span>
                </p>
            </div>
            <div>
                <span class="text-muted small"><i class="bi bi-clock"></i> Cập nhật hệ thống lần cuối: Hôm nay</span>
            </div>
        </div>
    </div>

    <div class="container mb-5">
        <div class="row g-4">
            
            <div class="col-md-4 col-sm-6">
                <a href="/danhmuc" class="admin-card">
                    <i class="bi bi-folder2-open admin-icon"></i>
                    <div class="admin-title">Quản Lý Danh Mục</div>
                    <div class="admin-desc">Thêm, sửa, xóa các nhóm phần mềm (HĐH, Diệt Virus...)</div>
                </a>
            </div>

            <div class="col-md-4 col-sm-6">
                <a href="/sanpham" class="admin-card">
                    <i class="bi bi-box-seam admin-icon"></i>
                    <div class="admin-title">Quản Lý Phần Mềm</div>
                    <div class="admin-desc">Quản lý danh sách sản phẩm, giá bán, cấu hình, hình ảnh</div>
                </a>
            </div>

            <div class="col-md-4 col-sm-6">
                <a href="/khobanquyen" class="admin-card">
                    <i class="bi bi-key admin-icon"></i>
                    <div class="admin-title">Kho Bản Quyền (Keys)</div>
                    <div class="admin-desc">Nhập hàng loạt mã kích hoạt, quản lý tồn kho và trạng thái</div>
                </a>
            </div>

            <div class="col-md-4 col-sm-6">
                <a href="/donhang" class="admin-card position-relative">
                    <i class="bi bi-cart-check admin-icon"></i>
                    <div class="admin-title">Quản Lý Đơn Hàng</div>
                    <div class="admin-desc">Duyệt đơn, kiểm tra thanh toán và tự động xuất key cho khách</div>
                </a>
            </div>

            <% if (user && user.vaiTro === 'QuanTriVien') { %>
            <div class="col-md-4 col-sm-6">
                <a href="/nguoidung" class="admin-card position-relative">
                    <i class="bi bi-people admin-icon"></i>
                    <div class="admin-title">Tài Khoản & Nhân Sự</div>
                    <div class="admin-desc">Cấp quyền nhân viên, quản lý danh sách khách hàng hệ thống</div>
                </a>
            </div>
            <% } %>

            <div class="col-md-4 col-sm-6">
                <a href="/thongke" class="admin-card position-relative">
                    <i class="bi bi-graph-up-arrow admin-icon"></i>
                    <div class="admin-title">Báo Cáo Doanh Thu</div>
                    <div class="admin-desc">Xem biểu đồ lợi nhuận, sản phẩm bán chạy theo tháng/quý</div>
                </a>
            </div>

        </div>
    </div>

    <%- include('footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>