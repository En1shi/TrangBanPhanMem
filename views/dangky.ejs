<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= title || 'Đăng Ký Tài Khoản - PKSoft Store' %>
    </title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <%- include('style') %>
</head>

<body>

    <%- include('navbar') %>

        <div class="container login-wrapper">
            <div class="login-card">
                <div class="text-center mb-4">
                    <i class="bi bi-person-plus-fill login-logo"></i>
                    <h3 class="fw-bold text-dark">Đăng Ký Tài Khoản</h3>
                    <p class="text-muted small">Tham gia cùng chúng tôi để mua sắm phần mềm bản quyền</p>
                </div>

                <form id="formDangKy">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Họ và tên <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="hoTen" required placeholder="Nguyễn Văn A">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Số điện thoại</label>
                            <input type="tel" class="form-control" id="soDienThoai" placeholder="09...">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Email <span class="text-danger">*</span></label>
                        <input type="email" class="form-control" id="email" required placeholder="email@example.com">
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên đăng nhập <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="tenDangNhap" required
                            placeholder="Viết liền không dấu">
                        <div class="form-text">Dùng để đăng nhập thay cho email.</div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Mật khẩu <span class="text-danger">*</span></label>
                            <input type="password" class="form-control" id="matKhau" required minlength="6"
                                placeholder="Tối thiểu 6 ký tự">
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-bold">Xác nhận mật khẩu <span
                                    class="text-danger">*</span></label>
                            <input type="password" class="form-control" id="nhapLaiMatKhau" required>
                        </div>
                    </div>

                    <div id="thongBaoLoi" class="alert alert-danger d-none small py-2" role="alert"></div>
                    <div id="thongBaoThanhCong" class="alert alert-success d-none small py-2" role="alert"></div>

                    <button type="submit" class="btn btn-red w-100 py-2 fs-5 text-uppercase" id="btnSubmit">
                        Tạo Tài Khoản
                    </button>
                </form>

                <div class="text-center mt-4">
                    <p class="mb-1 text-muted">Đã có tài khoản? <a href="/dangnhap"
                            class="text-primary fw-bold text-decoration-none">Đăng nhập ngay</a></p>
                </div>
            </div>
        </div>

        <%- include('footer') %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

            <script>
                document.getElementById('formDangKy').addEventListener('submit', async function (e) {
                    e.preventDefault();

                    var matKhau = document.getElementById('matKhau').value;
                    var nhapLaiMatKhau = document.getElementById('nhapLaiMatKhau').value;
                    var alertBox = document.getElementById('thongBaoLoi');
                    var successBox = document.getElementById('thongBaoThanhCong');
                    var btnSubmit = document.getElementById('btnSubmit');

                    alertBox.classList.add('d-none');
                    successBox.classList.add('d-none');

                    // 1. Kiểm tra mật khẩu khớp nhau
                    if (matKhau !== nhapLaiMatKhau) {
                        alertBox.innerText = 'Mật khẩu xác nhận không khớp!';
                        alertBox.classList.remove('d-none');
                        return;
                    }

                    // 2. Gói dữ liệu
                    var data = {
                        hoTen: document.getElementById('hoTen').value,
                        soDienThoai: document.getElementById('soDienThoai').value,
                        email: document.getElementById('email').value,
                        tenDangNhap: document.getElementById('tenDangNhap').value,
                        matKhau: matKhau
                    };

                    btnSubmit.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Đang xử lý...';
                    btnSubmit.disabled = true;

                    try {
                        // Gọi API Đăng ký
                        var response = await fetch('/dangky', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(data)
                        });

                        var result = await response.json();

                        if (response.ok) {
                            // Thành công
                            document.getElementById('formDangKy').reset();
                            successBox.innerHTML = 'Đăng ký thành công! Đang chuyển hướng đến trang Đăng Nhập...';
                            successBox.classList.remove('d-none');

                            // Delay 2 giây rồi chuyển trang
                            setTimeout(() => {
                                window.location.href = '/dangnhap';
                            }, 2000);
                        } else {
                            // Báo lỗi (VD: Trùng email, trùng tên đăng nhập)
                            alertBox.innerText = result.loi || 'Có lỗi xảy ra, vui lòng thử lại sau!';
                            alertBox.classList.remove('d-none');
                            btnSubmit.innerHTML = 'Tạo Tài Khoản';
                            btnSubmit.disabled = false;
                        }
                    } catch (error) {
                        alertBox.innerText = 'Lỗi kết nối đến máy chủ!';
                        alertBox.classList.remove('d-none');
                        btnSubmit.innerHTML = 'Tạo Tài Khoản';
                        btnSubmit.disabled = false;
                    }
                });
            </script>
</body>

</html>