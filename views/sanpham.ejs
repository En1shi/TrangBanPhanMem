<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= title || 'Danh sách sản phẩm - PKStore' %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <%- include('style')%>
</head>

<body>
    <%- include('navbar')%>
        <div class="container my-5">
            <div class="row">

                <div class="col-lg-3 col-md-4 mb-4">
                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-danger text-white fw-bold text-uppercase">
                            <i class="bi bi-list-ul me-2"></i> Danh Mục Phần Mềm
                        </div>
                        <div class="list-group list-group-flush">

                            <a href="/sanpham/danhsach"
                                class="list-group-item list-group-item-action <%= !danhMucHienTai ? 'active bg-light text-danger fw-bold border-start border-danger border-4' : '' %>">
                                <i class="bi bi-grid-fill me-2 text-muted"></i> Tất cả phần mềm
                            </a>

                            <% danhMucs.forEach(dm=> { %>
                                <a href="/sanpham/danhsach?danhmuc=<%= dm._id %>"
                                    class="list-group-item list-group-item-action <%= danhMucHienTai == dm._id ? 'active bg-light text-danger fw-bold border-start border-danger border-4' : '' %>">
                                    <i class="bi bi-chevron-right me-2 text-muted" style="font-size: 0.8rem;"></i>
                                    <%= dm.tenDanhMuc %>
                                </a>
                            <% }) %>

                        </div>
                    </div>
                </div>

                <div class="col-lg-9 col-md-8">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="fw-bold text-uppercase text-secondary mb-0">Danh sách sản phẩm</h4>
                    </div>

                    <div class="row">
                        <% if (sanPhams.length> 0) { %>
                            <% sanPhams.forEach(sp=> { %>
                                <div class="col-lg-4 col-md-6 mb-4">
                                    <div class="card h-100 shadow-sm border-0 product-card">
                                        
                                        <a href="/sanpham/chi-tiet/<%= sp._id %>" class="text-center p-3">
                                            <% if (sp.hinhAnh && sp.hinhAnh.length > 0) { %>
                                                <img src="/images/<%= sp.hinhAnh[0] %>" class="card-img-top img-fluid" alt="<%= sp.tenSanPham %>" style="height: 160px; object-fit: contain;">
                                            <% } else { %>
                                                <i class="bi bi-box-seam text-secondary" style="font-size: 6rem;"></i>
                                            <% } %>
                                        </a>

                                        <div class="card-body text-center d-flex flex-column pt-0">
                                            <a href="/sanpham/chi-tiet/<%= sp._id %>" class="text-decoration-none text-dark">
                                                <h6 class="card-title fw-bold mb-2"><%= sp.tenSanPham %></h6>
                                            </a>
                                            <div class="mt-auto">
                                                <p class="text-danger fw-bold fs-5 mb-0"><%= sp.giaBan.toLocaleString('vi-VN') %>đ</p>
                                            </div>
                                        </div>

                                        <div class="card-footer bg-white border-0 pb-3 pt-0">
                                            <% if (typeof user !=='undefined' && user) { %>
                                                <button onclick="themVaoGio('<%= sp._id %>')" class="btn btn-danger w-100 fw-bold shadow-sm">
                                                    <i class="bi bi-cart-plus me-2"></i> Mua ngay
                                                </button>
                                            <% } else { %>
                                                <button onclick="yeuCauDangNhap()" class="btn btn-danger w-100 fw-bold shadow-sm">
                                                    <i class="bi bi-cart-plus me-2"></i> Mua ngay
                                                </button>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="col-12 text-center py-5">
                                <i class="bi bi-inboxes text-muted mb-3" style="font-size: 4rem;"></i>
                                <h5 class="text-muted">Không tìm thấy phần mềm nào trong danh mục này.</h5>
                            </div>
                        <% } %>
                    </div>
                </div>

            </div>
        </div>
        <%- include('footer')%>
            <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

            <script>
                // Hàm định dạng tiền tệ
                var formatCurrency = (number) => {
                    return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(number);
                };

                // Hàm Thêm vào giỏ hàng (Giống hệt trang chủ)
                async function themVaoGio(sanPhamId, soLuong = 1) {
                    try {
                        var response = await fetch('/giohang/api/them', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ sanPham_id: sanPhamId, soLuong: soLuong })
                        });
                        var data = await response.json();

                        if (response.ok) {
                            var cartBadge = document.getElementById('cartBadge');
                            if (cartBadge) {
                                cartBadge.innerText = data.cartCount;
                            }
                            alert('Đã thêm sản phẩm vào giỏ hàng thành công!');
                        } else {
                            alert('Lỗi: ' + (data.loi || 'Không thể thêm vào giỏ.'));
                        }
                    } catch (error) {
                        console.error('Lỗi khi thêm vào giỏ:', error);
                        alert('Lỗi kết nối đến máy chủ!');
                    }
                }

                function yeuCauDangNhap() {
                    alert("Bạn cần đăng nhập tài khoản để có thể mua phần mềm và nhận Key kích hoạt!");
                    window.location.href = "/dangnhap";
                }
            </script>
</body>

</html>