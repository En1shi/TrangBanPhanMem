<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= title || 'Đăng Nhập - PKStore' %>
    </title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <%- include('style') %>
</head>

<body>

    <%- include('navbar') %>

        <div class="container login-wrapper">
            <div class="login-card">
                <div class="text-center mb-4">
                    <i class="bi bi-shield-lock-fill login-logo"></i>
                    <h3 class="fw-bold text-dark">Đăng Nhập Hệ Thống</h3>
                    <p class="text-muted small">Vui lòng điền thông tin để tiếp tục</p>
                </div>

                <form id="formDangNhap">
                    <div class="mb-3">
                        <label for="tenDangNhap" class="form-label fw-bold">Tên đăng nhập <span
                                class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-person"></i></span>
                            <input type="text" class="form-control" id="tenDangNhap" required
                                placeholder="Nhập tên tài khoản">
                        </div>
                    </div>

                    <div class="mb-4">
                        <label for="matKhau" class="form-label fw-bold">Mật khẩu <span
                                class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-key"></i></span>
                            <input type="password" class="form-control" id="matKhau" required
                                placeholder="Nhập mật khẩu">
                        </div>
                    </div>

                    <div id="thongBaoLoi" class="alert alert-danger d-none small py-2" role="alert"></div>

                    <button type="submit" class="btn btn-red w-100 py-2 fs-5 text-uppercase" id="btnSubmit">
                        Đăng Nhập
                    </button>
                </form>

                <div class="text-center mt-4">
                    <p class="mb-1 text-muted">Chưa có tài khoản? <a href="/dangky"
                            class="text-danger fw-bold text-decoration-none">Đăng ký ngay</a></p>
                </div>
            </div>
        </div>

        <%- include('footer') %>

            <script>
    document.getElementById('formDangNhap').addEventListener('submit', async function (e) {
        e.preventDefault();

        var tenDangNhap = document.getElementById('tenDangNhap').value;
        var matKhau = document.getElementById('matKhau').value;
        var alertBox = document.getElementById('thongBaoLoi');
        var btnSubmit = document.getElementById('btnSubmit');

        alertBox.classList.add('d-none');
        btnSubmit.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Đang kiểm tra...';
        btnSubmit.disabled = true;

        var thongTinGuiDi = {
            tenDangNhap: tenDangNhap,
            matKhau: matKhau
        };

        try {
            var response = await fetch('/auth/dangnhap', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(thongTinGuiDi) 
            });

            var ketQua = await response.json();

            if (response.ok) {
                if (ketQua.vaiTro === 'Admin' || ketQua.vaiTro === 'NhanVien') {
                    window.location.href = '/admin';
                } else {
                    window.location.href = '/';
                }
            } else {
                // Nếu sai tài khoản hoặc mật khẩu
                alertBox.innerText = ketQua.loi || 'Đăng nhập thất bại!';
                alertBox.classList.remove('d-none');

                btnSubmit.innerHTML = 'Đăng Nhập';
                btnSubmit.disabled = false;
            }
        } catch (error) {
            // Nếu sập server
            alertBox.innerText = 'Lỗi kết nối đến máy chủ!';
            alertBox.classList.remove('d-none');
            
            btnSubmit.innerHTML = 'Đăng Nhập';
            btnSubmit.disabled = false;
        }
    });
</script>
</body>

</html>