<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Quản lý Sản Phẩm - PKStore Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <%- include('style') %>

</head>
<body>
    <%- include('navbar') %>

    <div class="container my-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0">Danh Sách Phần Mềm</h2>
            <a href="/admin/sanpham/them" class="btn btn-red">
                <i class="bi bi-plus-lg"></i> Thêm sản phẩm mới
            </a>
        </div>

        <div class="admin-container">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th width="5%">STT</th>
                        <th width="10%">Hình ảnh</th>
                        <th width="25%">Tên Sản Phẩm</th>
                        <th width="15%">Danh Mục</th>
                        <th width="15%">Giá Bán</th>
                        <th width="10%" class="text-center">Trạng Thái</th>
                        <th width="20%" class="text-center">Thao Tác</th>
                    </tr>
                </thead>
                <tbody id="bangSanPham">
                    <tr><td colspan="7" class="text-center text-muted">Đang tải dữ liệu...</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <%- include('footer') %>

    <script>
        // Định dạng tiền VNĐ
        var formatCurrency = (number) => new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(number);

        // Gọi API lấy danh sách sản phẩm
        async function loadDanhSach() {
            try {
                var response = await fetch('/api/sanpham');
                var sanPhams = await response.json();
                var tbody = document.getElementById('bangSanPham');
                
                if (sanPhams.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="7" class="text-center">Chưa có sản phẩm nào.</td></tr>';
                    return;
                }

                tbody.innerHTML = '';
                sanPhams.forEach((sp, index) => {
                    // Xử lý hiển thị ảnh hoặc icon mặc định
                    let hinhAnhHtml = sp.hinhAnh && sp.hinhAnh.length > 0 
                        ? `<img src="${sp.hinhAnh[0]}" class="img-thumbnail-sm" alt="Ảnh SP">` 
                        : `<i class="bi bi-box-seam fs-2 text-secondary"></i>`;
                    
                    // Xử lý tên danh mục (Vì đã dùng populate ở backend)
                    let tenDanhMuc = sp.danhMuc_id ? sp.danhMuc_id.tenDanhMuc : '<span class="text-danger">Lỗi danh mục</span>';

                    let trangThai = sp.hienThi ? '<span class="badge bg-success">Đang hiện</span>' : '<span class="badge bg-secondary">Đang ẩn</span>';

                    tbody.innerHTML += `
                        <tr>
                            <td>${index + 1}</td>
                            <td>${hinhAnhHtml}</td>
                            <td class="fw-bold text-dark">${sp.tenSanPham}</td>
                            <td>${tenDanhMuc}</td>
                            <td class="text-danger fw-bold">${formatCurrency(sp.giaBan)}</td>
                            <td class="text-center">${trangThai}</td>
                            <td class="text-center">
                                <a href="/admin/sanpham/sua/${sp._id}" class="btn btn-sm btn-warning me-1">
                                    <i class="bi bi-pencil-square"></i> Sửa
                                </a>
                                <button class="btn btn-sm btn-danger" onclick="xoaSanPham('${sp._id}')">
                                    <i class="bi bi-trash"></i> Xóa
                                </button>
                            </td>
                        </tr>
                    `;
                });
            } catch (error) {
                document.getElementById('bangSanPham').innerHTML = '<tr><td colspan="7" class="text-danger text-center">Lỗi tải dữ liệu!</td></tr>';
            }
        }

        // Hàm Xóa Sản Phẩm
        async function xoaSanPham(id) {
            if(confirm("Bạn có chắc chắn muốn xóa sản phẩm này? Mọi thông tin sẽ không thể khôi phục!")) {
                try {
                    var response = await fetch('/api/sanpham/' + id, { method: 'DELETE' });
                    if(response.ok) {
                        alert('Đã xóa sản phẩm thành công!');
                        loadDanhSach(); // Tải lại bảng sau khi xóa
                    } else {
                        alert("Lỗi khi xóa từ server!");
                    }
                } catch (error) {
                    alert("Lỗi kết nối máy chủ");
                }
            }
        }

        document.addEventListener('DOMContentLoaded', loadDanhSach);
    </script>
</body>
</html>