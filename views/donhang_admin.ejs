<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <title>Quản lý Đơn Hàng - PKStore Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <%- include('style') %>
</head>

<body>
    <%- include('navbar') %>

        <div class="container my-4">
            <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
                <h2 class="fw-bold mb-0">Quản Lý Đơn Hàng</h2>

                <div class="d-flex align-items-center gap-2">
                    <div class="btn-group" role="group">
                        <input type="radio" class="btn-check" name="btnradio" id="btnAll" autocomplete="off" checked
                            onclick="hienThiBang('tat_ca')">
                        <label class="btn btn-outline-secondary" for="btnAll">Tất cả</label>

                        <input type="radio" class="btn-check" name="btnradio" id="btnError" autocomplete="off"
                            onclick="hienThiBang('su_co')">
                        <label class="btn btn-outline-danger fw-bold" for="btnError">
                            Sự cố <span class="badge bg-danger ms-1" id="demSuCo">0</span>
                        </label>
                    </div>

                    <button class="btn btn-dark" onclick="loadDanhSachDonHang()">
                        <i class="bi bi-arrow-clockwise"></i> Tải lại
                    </button>
                </div>
            </div>

            <div class="admin-container">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th width="10%">Mã Đơn</th>
                            <th width="15%">Ngày Đặt</th>
                            <th width="20%">Khách Hàng</th>
                            <th width="15%">Tổng Tiền</th>
                            <th width="15%">Thanh Toán</th>
                            <th width="10%" class="text-center">Trạng Thái</th>
                            <th width="15%" class="text-center">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody id="bangDonHang">
                        <tr>
                            <td colspan="7" class="text-center text-muted">Đang tải dữ liệu...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <%- include('footer') %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
            <script>
                var formatCurrency = (number) => new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(number);
                var formatMaDon = (id) => 'DH-' + id.slice(-5).toUpperCase();

                let danhSachGoc = [];

                // 1. CẬP NHẬT ĐƯỜNG DẪN LẤY DANH SÁCH
                async function loadDanhSachDonHang() {
                    try {
                        // Đã sửa thành /don-hang/api/danh-sach
                        var response = await fetch('/donhang/api/danhsach');
                        danhSachGoc = await response.json();

                        var soDonLoi = danhSachGoc.filter(dh => dh.loiBaoCao).length;
                        document.getElementById('demSuCo').innerText = soDonLoi;

                        document.getElementById('btnAll').checked = true;
                        hienThiBang('tat_ca');
                    } catch (error) {
                        document.getElementById('bangDonHang').innerHTML = '<tr><td colspan="7" class="text-danger text-center">Lỗi tải dữ liệu!</td></tr>';
                    }
                }

                function hienThiBang(loai) {
                    var tbody = document.getElementById('bangDonHang');
                    tbody.innerHTML = '';

                    let duLieuHienThi = danhSachGoc;
                    if (loai === 'su_co') {
                        duLieuHienThi = danhSachGoc.filter(dh => dh.loiBaoCao);
                    }

                    if (duLieuHienThi.length === 0) {
                        tbody.innerHTML = `<tr><td colspan="7" class="text-center py-4 text-muted">Không có đơn hàng nào trong danh mục này.</td></tr>`;
                        return;
                    }

                    duLieuHienThi.forEach(dh => {
                        var ngayDat = new Date(dh.createdAt).toLocaleString('vi-VN');
                        let actionButtons = '';
                        let badgeTrangThai = '';

                        if (dh.trangThai === 'ChoThanhToan') {
                            badgeTrangThai = '<span class="badge bg-warning text-dark">Chờ thanh toán</span>';
                            actionButtons = `
                <button class="btn btn-sm btn-success mb-1 w-100" onclick="capNhatTrangThai('${dh._id}', 'DaThanhToan')">Duyệt Đơn</button>
                <button class="btn btn-sm btn-danger w-100" onclick="capNhatTrangThai('${dh._id}', 'DaHuy')">Hủy</button>
            `;
                        } else if (dh.trangThai === 'DaThanhToan' || dh.trangThai === 'HoanThanh') {
                            badgeTrangThai = '<span class="badge bg-success">Hoàn thành</span>';
                            actionButtons = `<span class="text-muted small">Đã xử lý</span>`;
                        } else {
                            badgeTrangThai = '<span class="badge bg-secondary">Đã Hủy</span>';
                            actionButtons = `-`;
                        }

                        let dongCanhBaoLoi = '';
                        if (dh.loiBaoCao) {
                            dongCanhBaoLoi = `
                <div class="alert alert-danger p-2 mt-2 mb-0 small text-start">
                    <strong><i class="bi bi-exclamation-triangle-fill"></i> Khách báo lỗi:</strong> ${dh.loiBaoCao}
                </div>
            `;
                            actionButtons += `
                <button class="btn btn-sm btn-warning mt-2 w-100 fw-bold shadow-sm" onclick="xuLyLoi('${dh._id}')">
                    <i class="bi bi-wrench"></i> Xử lý xong
                </button>
            `;
                        }

                        tbody.innerHTML += `
            <tr class="${dh.loiBaoCao ? 'table-danger' : ''}">
                <td class="fw-bold text-danger">${formatMaDon(dh._id)}</td>
                <td class="small text-muted">${ngayDat}</td>
                <td>
                    <strong>${dh.hoTen}</strong><br>
                    <span class="small text-muted">${dh.soDienThoai}</span>
                    ${dongCanhBaoLoi}
                </td>
                <td class="text-danger fw-bold">${formatCurrency(dh.tongTien)}</td>
                <td class="fw-bold">${dh.phuongThucThanhToan}</td>
                <td class="text-center">${badgeTrangThai}</td>
                <td class="text-center" style="min-width: 110px;">${actionButtons}</td>
            </tr>
        `;
                    });
                }

                // 2. CẬP NHẬT ĐƯỜNG DẪN XỬ LÝ LỖI
                async function xuLyLoi(id) {
                    if (confirm("Xác nhận đã cấp lại Key hoặc hỗ trợ xong cho khách hàng này?")) {
                        try {
                            var res = await fetch(`/donhang/api/xu-ly-loi/${id}`, { method: 'PUT' });
                            if (res.ok) {
                                alert("Đã đánh dấu xử lý xong!");
                                loadDanhSachDonHang();
                            } else {
                                alert("Lỗi khi cập nhật!");
                            }
                        } catch (err) {
                            alert("Lỗi kết nối mạng!");
                        }
                    }
                }

                // 3. CẬP NHẬT ĐƯỜNG DẪN ĐỔI TRẠNG THÁI (DUYỆT/HỦY)
                async function capNhatTrangThai(id, trangThaiMoi) {
                    let tinNhan = trangThaiMoi === 'DaThanhToan' ? "DUYỆT đơn hàng này?" : "HỦY đơn hàng này?";
                    if (confirm(tinNhan)) {
                        try {
                            // Sửa lại theo router mới: /don-hang/api/cap-nhat-trang-thai/:id
                            var res = await fetch(`/donhang/api/cap-nhat-trang-thai/${id}`, {
                                method: 'PUT',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ trangThai: trangThaiMoi })
                            });

                            if (res.ok) {
                                alert('Thành công!');
                                loadDanhSachDonHang();
                            } else {
                                alert('Lỗi khi cập nhật');
                            }
                        } catch (err) {
                            alert('Lỗi kết nối máy chủ!');
                        }
                    }
                }

                document.addEventListener('DOMContentLoaded', loadDanhSachDonHang);
            </script>
</body>

</html>