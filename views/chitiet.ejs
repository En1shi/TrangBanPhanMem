<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <title><%= title %> - PKStore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <%- include('style') %>
</head>

<body>
    <%- include('navbar') %>

        <div class="container my-5">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-danger">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a href="/san-pham/danh-sach" class="text-decoration-none text-danger">Phần mềm</a></li>
                    <li class="breadcrumb-item active" aria-current="page">
                        <%= sanPham.danhMuc_id ? sanPham.danhMuc_id.tenDanhMuc : 'Sản phẩm' %>
                    </li>
                </ol>
            </nav>

            <div class="row bg-white p-4 rounded shadow-sm">
                <div class="col-md-5 mb-4 mb-md-0">
                    <div class="product-img-box text-center">
                        <% if (sanPham.hinhAnh && sanPham.hinhAnh.length > 0) { %>
                            <img src="/images/<%= sanPham.hinhAnh[0] %>" class="img-fluid rounded" alt="<%= sanPham.tenSanPham %>" style="max-height: 300px; object-fit: contain;">
                        <% } else { %>
                            <i class="bi bi-box-seam text-secondary" style="font-size: 10rem;"></i>
                        <% } %>
                    </div>
                </div>

                <div class="col-md-7">
                    <h1 class="fw-bold mb-3"><%= sanPham.tenSanPham %></h1>
                    <p class="text-muted mb-4">Danh mục: <strong class="text-dark">
                            <%= sanPham.danhMuc_id ? sanPham.danhMuc_id.tenDanhMuc : 'Chưa phân loại' %>
                        </strong></p>

                    <div class="price-box mb-4">
                        <% if (sanPham.giaGoc && sanPham.giaGoc > sanPham.giaBan) { %>
                            <div class="text-muted text-decoration-line-through fs-5">
                                <%= sanPham.giaGoc.toLocaleString('vi-VN') %>đ
                            </div>
                        <% } %>
                        <div class="text-danger fw-bold" style="font-size: 2.5rem;">
                            <%= sanPham.giaBan.toLocaleString('vi-VN') %>đ
                        </div>
                    </div>

                    <div class="mb-4">
                        <p class="mb-1"><i class="bi bi-check2-circle text-success me-2"></i>Bảo hành chính hãng trọn vòng đời sản phẩm.</p>
                        <p class="mb-1"><i class="bi bi-check2-circle text-success me-2"></i>Hỗ trợ cài đặt từ xa qua UltraViewer/TeamViewer.</p>
                        <p class="mb-1"><i class="bi bi-check2-circle text-success me-2"></i>Gửi mã bản quyền tự động qua Email trong 5 phút.</p>
                    </div>

                    <hr>

                    <div class="d-flex align-items-center mt-4">
                        <label class="fw-bold me-3">Số lượng:</label>
                        <input type="number" id="soLuongMua" class="form-control text-center me-3" value="1" min="1" style="width: 80px;">

                        <% if (typeof user !=='undefined' && user) { %>
                            <button onclick="themVaoGio('<%= sanPham._id %>')" class="btn btn-danger btn-lg w-100 fw-bold shadow-sm">
                                <i class="bi bi-cart-check-fill me-2"></i> Thêm vào giỏ
                            </button>
                        <% } else { %>
                            <button onclick="yeuCauDangNhap()" class="btn btn-danger btn-lg w-100 fw-bold shadow-sm">
                                <i class="bi bi-cart-plus-fill me-2"></i> Thêm vào giỏ
                            </button>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="row mt-5">
                <div class="col-md-8 mb-4">
                    <div class="bg-white p-4 rounded shadow-sm h-100">
                        <h4 class="fw-bold border-bottom pb-2 mb-4">Mô Tả Sản Phẩm</h4>
                        <div style="white-space: pre-wrap; line-height: 1.8;">
                            <%= sanPham.moTaChiTiet || 'Đang cập nhật mô tả...' %>
                        </div>
                    </div>
                </div>

                <div class="col-md-4 mb-4">
                    <div class="bg-white p-4 rounded shadow-sm h-100">
                        <h4 class="fw-bold border-bottom pb-2 mb-4">Cấu Hình Tối Thiểu</h4>
                        <% if (sanPham.cauHinhToiThieu) { %>
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item px-0 py-3">
                                    <span class="fw-bold text-secondary d-block fs-6"><i class="bi bi-windows me-2"></i>Hệ điều hành</span>
                                    <span><%= sanPham.cauHinhToiThieu.os || 'Không yêu cầu' %></span>
                                </li>
                                <li class="list-group-item px-0 py-3">
                                    <span class="fw-bold text-secondary d-block fs-6"><i class="bi bi-memory me-2"></i>RAM tối thiểu</span>
                                    <span><%= sanPham.cauHinhToiThieu.ram || 'Không yêu cầu' %></span>
                                </li>
                                <li class="list-group-item px-0 py-3">
                                    <span class="fw-bold text-secondary d-block fs-6"><i class="bi bi-hdd me-2"></i>Dung lượng ổ cứng</span>
                                    <span><%= sanPham.cauHinhToiThieu.disk || 'Không yêu cầu' %></span>
                                </li>
                            </ul>
                        <% } else { %>
                            <p class="text-muted">Không có yêu cầu đặc biệt về cấu hình.</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <%- include('footer') %>
        
        <script>
            // Hàm thêm giỏ hàng phiên bản đặc biệt (Đọc số lượng từ ô input)
            async function themVaoGio(sanPhamId) {
                // Lấy con số người dùng đã nhập
                var soLuongCanMua = document.getElementById('soLuongMua').value;

                try {
                    // Gọi đúng URL API mới
                    var response = await fetch('/giohang/api/them', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ sanPham_id: sanPhamId, soLuong: soLuongCanMua })
                    });
                    
                    var data = await response.json();

                    if (response.ok) {
                        // Cập nhật số trên icon Giỏ hàng
                        var cartBadge = document.getElementById('cartBadge');
                        if (cartBadge) {
                            cartBadge.innerText = data.cartCount;
                        }
                        alert('Đã thêm ' + soLuongCanMua + ' sản phẩm vào giỏ hàng thành công!');
                    } else {
                        alert('Lỗi: ' + (data.loi || 'Không thể thêm vào giỏ.'));
                    }
                } catch (error) {
                    console.error('Lỗi khi thêm vào giỏ:', error);
                    alert('Lỗi kết nối đến máy chủ!');
                }
            }

            function yeuCauDangNhap() {
                alert("Bạn cần đăng nhập tài khoản để có thể mua phần mềm và nhận Key kích hoạt!");
                window.location.href = "/dangnhap"; // Nhớ đảm bảo link này khớp với router auth của bạn nhé
            }
        </script>
</body>
</html>