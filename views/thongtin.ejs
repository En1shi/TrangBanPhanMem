<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <%- include('style') %>
</head>

<body>
    <%- include('navbar') %>

        <div class="container my-5">
            <h2 class="fw-bold mb-4">Hồ Sơ Của Tôi</h2>

            <div class="profile-container">
                <ul class="nav nav-tabs mb-4" id="profileTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="info-tab" data-bs-toggle="tab" data-bs-target="#info"
                            type="button" role="tab">
                            <i class="bi bi-person-lines-fill me-2"></i>Thông tin tài khoản
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="history-tab" data-bs-toggle="tab" data-bs-target="#history"
                            type="button" role="tab">
                            <i class="bi bi-clock-history me-2"></i>Lịch sử mua hàng
                        </button>
                    </li>
                </ul>

                <div class="tab-content" id="profileTabsContent">

                    <div class="tab-pane fade show active" id="info" role="tabpanel">
                        <div class="row">
                            <div class="col-md-6">
                                <form id="formCapNhatThongTin" action="/nguoidung/thongtin" method="POST">

                                    <% if (typeof thanhCong !=='undefined' && thanhCong) { %>
                                        <div class="alert alert-success py-2"><i class="bi bi-check-circle"></i> Cập
                                            nhật thông tin thành công!</div>
                                        <% } %>
                                            <% if (typeof loi !=='undefined' && loi==='sai-mat-khau' ) { %>
                                                <div class="alert alert-danger py-2">Mật khẩu cũ không chính xác!</div>
                                                <% } %>
                                                    <% if (typeof loi !=='undefined' && loi==='khong-khop' ) { %>
                                                        <div class="alert alert-danger py-2">Mật khẩu mới không khớp
                                                            nhau!</div>
                                                        <% } %>

                                                            <div class="mb-3">
                                                                <label class="form-label fw-bold">Họ và Tên</label>
                                                                <input type="text" class="form-control" name="hoTen"
                                                                    value="<%= user.hoTen %>" required>
                                                            </div>

                                                            <div class="mb-3">
                                                                <label class="form-label fw-bold">Email (Không thể
                                                                    đổi)</label>
                                                                <input type="email" class="form-control bg-light"
                                                                    value="<%= user.email %>" readonly>
                                                            </div>

                                                            <div class="mb-3">
                                                                <label class="form-label fw-bold">Số điện thoại</label>
                                                                <input type="text" class="form-control"
                                                                    name="soDienThoai" value="<%= user.soDienThoai %>"
                                                                    required>
                                                            </div>

                                                            <div class="mb-3">
                                                                <label class="form-label fw-bold">Loại tài khoản</label>
                                                                <input type="text"
                                                                    class="form-control bg-light text-danger fw-bold"
                                                                    value="<%= user.vaiTro === 'Admin' || user.vaiTro === 'QuanTriVien' ? 'Quản Trị Viên' : 'Khách Hàng' %>"
                                                                    readonly>
                                                            </div>

                                                            <hr class="my-4 border-secondary">
                                                            <h5 class="fw-bold mb-3 text-secondary"
                                                                style="font-size: 1.1rem;">Đổi Mật Khẩu <span
                                                                    class="text-muted fw-normal"
                                                                    style="font-size: 0.9rem;">(Bỏ trống nếu không
                                                                    đổi)</span></h5>

                                                            <div class="mb-3">
                                                                <input type="password" class="form-control"
                                                                    name="matKhauCu" placeholder="Mật khẩu hiện tại...">
                                                            </div>
                                                            <div class="row">
                                                                <div class="col-md-6 mb-3">
                                                                    <input type="password" class="form-control"
                                                                        name="matKhauMoi" placeholder="Mật khẩu mới...">
                                                                </div>
                                                                <div class="col-md-6 mb-3">
                                                                    <input type="password" class="form-control"
                                                                        name="xacNhanMatKhau"
                                                                        placeholder="Xác nhận mật khẩu mới...">
                                                                </div>
                                                            </div>

                                                            <button type="submit"
                                                                class="btn btn-danger w-100 fw-bold py-2 mt-3 fs-5 shadow-sm">
                                                                <i class="bi bi-save me-2"></i> LƯU THAY ĐỔI
                                                            </button>

                                </form>
                            </div>
                            <div class="col-md-6 d-flex align-items-center justify-content-center flex-column">
                                <i class="bi bi-person-circle text-secondary mb-3" style="font-size: 8rem;"></i>
                                <h4 class="fw-bold">
                                    <%= user.hoTen %>
                                </h4>
                                <span class="badge bg-success">Thành viên PKStore</span>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="history" role="tabpanel">
                        <% if (lichSuDonHang.length===0) { %>
                            <div class="text-center py-5 text-muted">
                                <i class="bi bi-bag-x" style="font-size: 4rem;"></i>
                                <h5 class="mt-3">Bạn chưa có đơn hàng nào.</h5>
                                <a href="/sanpham/danhsach" class="btn btn-danger mt-3">Mua sắm ngay</a>
                            </div>
                            <% } else { %>
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Mã Đơn</th>
                                                <th>Ngày Mua</th>
                                                <th>Sản Phẩm</th>
                                                <th>Tổng Tiền</th>
                                                <th class="text-center">Trạng Thái</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% lichSuDonHang.forEach(dh=> { %>
                                                <tr>
                                                    <td class="fw-bold text-danger">DH-<%=
                                                            dh._id.toString().slice(-5).toUpperCase() %>
                                                    </td>
                                                    <td class="text-muted small">
                                                        <%= new Date(dh.createdAt).toLocaleString('vi-VN') %>
                                                    </td>
                                                    <td>
                                                        <ul class="list-unstyled mb-0 small">
                                                            <% dh.danhSachSanPham.forEach(sp=> { %>
                                                                <li><i class="bi bi-caret-right-fill text-muted"
                                                                        style="font-size: 0.7rem;"></i>
                                                                    <%= sp.tenSanPham %> <strong>(x<%= sp.soLuong %>
                                                                                )</strong>
                                                                </li>
                                                                <% }) %>
                                                        </ul>
                                                    </td>
                                                    <td class="fw-bold">
                                                        <%= dh.tongTien.toLocaleString('vi-VN') %>đ
                                                    </td>
                                                    <td class="text-center">
                                                        <% if (dh.trangThai==='ChoThanhToan' ) { %>
                                                            <span class="badge bg-warning text-dark"><i
                                                                    class="bi bi-hourglass-split"></i> Chờ duyệt</span>
                                                            <% } else if (dh.trangThai==='DaThanhToan' ||
                                                                dh.trangThai==='HoanThanh' ) { %>
                                                                <span class="badge bg-success"><i
                                                                        class="bi bi-check-circle"></i> Hoàn
                                                                    thành</span>

                                                                <button
                                                                    class="btn btn-sm btn-outline-danger mt-2 d-block w-100"
                                                                    onclick="moPopupBaoLoi('<%= dh._id %>')">
                                                                    <i class="bi bi-exclamation-triangle"></i> Báo lỗi
                                                                    Key
                                                                </button>

                                                                <% if (dh.loiBaoCao) { %>
                                                                    <small class="text-danger mt-1 d-block"><i
                                                                            class="bi bi-info-circle"></i> Đang chờ xử
                                                                        lý sự cố</small>
                                                                    <% } %>

                                                                        <% } else { %>
                                                                            <span class="badge bg-secondary"><i
                                                                                    class="bi bi-x-circle"></i> Đã
                                                                                hủy</span>
                                                                            <% } %>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                                <% } %>
                    </div>

                </div>
            </div>
        </div>
        <div class="modal fade" id="modalBaoLoi" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title"><i class="bi bi-exclamation-triangle-fill me-2"></i>Báo cáo sự cố đơn
                            hàng</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                            aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p>Chúng tôi rất xin lỗi vì sự cố bạn đang gặp phải. Vui lòng mô tả chi tiết lỗi (Key không hợp
                            lệ, Key bị trùng, lỗi cài đặt...) để kỹ thuật viên hỗ trợ nhanh nhất.</p>
                        <input type="hidden" id="donHangLoiId">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Mô tả chi tiết sự cố:</label>
                            <textarea class="form-control" id="noiDungLoi" rows="4"
                                placeholder="Ví dụ: Khi tôi nhập Key thì phần mềm báo lỗi Error Code 0x800..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
                        <button type="button" class="btn btn-danger" onclick="guiBaoLoi()">Gửi Báo Cáo</button>
                    </div>
                </div>
            </div>
        </div>
        <script>
            function moPopupBaoLoi(idDonHang) {
                document.getElementById('donHangLoiId').value = idDonHang;
                document.getElementById('noiDungLoi').value = ''; // Xóa chữ cũ (nếu có)

                var modal = new bootstrap.Modal(document.getElementById('modalBaoLoi'));
                modal.show();
            }

            async function guiBaoLoi() {
                var id = document.getElementById('donHangLoiId').value;
                var noiDung = document.getElementById('noiDungLoi').value.trim();

                if (!noiDung) {
                    alert('Vui lòng nhập mô tả lỗi!');
                    return;
                }

                try {
                    var res = await fetch('/donhang/api/bao-loi/' + id, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ noiDungLoi: noiDung })
                    });

                    var data = await res.json();

                    if (res.ok) {
                        alert(data.thongBao);
                        window.location.reload();
                    } else {
                        alert('Lỗi: ' + data.loi);
                    }
                } catch (err) {
                    alert('Lỗi kết nối đến máy chủ!');
                }
            }
        </script>

        <%- include('footer') %>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>