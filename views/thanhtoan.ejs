<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <%- include('style') %>
</head>
<body>
    <%- include('navbar') %>

    <div class="container my-5">
        <h2 class="fw-bold mb-4">Thanh Toán</h2>

        <form id="formThanhToan">
            <div class="row">
                <div class="col-lg-7 mb-4">
                    <div class="checkout-box">
                        <h5 class="fw-bold mb-3 border-bottom pb-2">Thông Tin Nhận Key (Email)</h5>
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Họ và Tên <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="hoTen" required value="<%= user ? user.hoTen : '' %>">
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Email nhận Key <span class="text-danger">*</span></label>
                                <input type="email" class="form-control border-danger" id="email" required value="<%= user ? user.email : '' %>" placeholder="Vui lòng nhập chính xác">
                                <div class="form-text text-danger">Mã kích hoạt sẽ được gửi vào email này!</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Số điện thoại <span class="text-danger">*</span></label>
                                <input type="tel" class="form-control" id="soDienThoai" required>
                            </div>
                        </div>

                        <h5 class="fw-bold mb-3 mt-4 border-bottom pb-2">Phương thức thanh toán</h5>
                        
                        <div class="form-check mb-2 p-3 border rounded">
                            <input class="form-check-input ms-1" type="radio" name="phuongThuc" id="ptChuyenKhoan" value="ChuyenKhoan" checked>
                            <label class="form-check-label fw-bold ms-2" for="ptChuyenKhoan">
                                <i class="bi bi-bank text-primary"></i> Chuyển khoản ngân hàng (Quét mã QR)
                            </label>
                        </div>
                        <div class="form-check mb-2 p-3 border rounded">
                            <input class="form-check-input ms-1" type="radio" name="phuongThuc" id="ptMomo" value="Momo">
                            <label class="form-check-label fw-bold ms-2" for="ptMomo">
                                <i class="bi bi-wallet2 text-danger"></i> Ví điện tử MoMo
                            </label>
                        </div>

                        <div class="mb-3 mt-4">
                            <label class="form-label fw-bold">Ghi chú thêm (Tùy chọn)</label>
                            <textarea class="form-control" id="ghiChu" rows="3"></textarea>
                        </div>
                    </div>
                </div>

                <div class="col-lg-5">
                    <div class="checkout-box">
                        <h5 class="fw-bold mb-3 border-bottom pb-2">Đơn Hàng Của Bạn</h5>
                        
                        <div class="mb-3">
                            <% cart.forEach(item => { %>
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <div class="d-flex align-items-center">
                                        <span class="badge bg-secondary me-2"><%= item.soLuong %></span>
                                        <span class="text-truncate" style="max-width: 200px;"><%= item.tenSanPham %></span>
                                    </div>
                                    <span class="fw-bold"><%= (item.giaBan * item.soLuong).toLocaleString('vi-VN') %>đ</span>
                                </div>
                            <% }) %>
                        </div>
                        
                        <hr>
                        <div class="d-flex justify-content-between mb-4">
                            <span class="fw-bold fs-5">TỔNG CỘNG:</span>
                            <span class="fw-bold fs-4 text-danger"><%= tongTien.toLocaleString('vi-VN') %>đ</span>
                        </div>

                        <button type="submit" class="btn btn-red w-100 py-3 fs-5 fw-bold" id="btnDatHang">
                            <i class="bi bi-check-circle"></i> XÁC NHẬN ĐẶT HÀNG
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <%- include('footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('formThanhToan').addEventListener('submit', async function(e) {
            e.preventDefault();

            // Tìm phương thức thanh toán đang được check
            const ptThanhToan = document.querySelector('input[name="phuongThuc"]:checked').value;

            const data = {
                hoTen: document.getElementById('hoTen').value,
                email: document.getElementById('email').value,
                soDienThoai: document.getElementById('soDienThoai').value,
                ghiChu: document.getElementById('ghiChu').value,
                phuongThucThanhToan: ptThanhToan
            };

            const btn = document.getElementById('btnDatHang');
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Đang xử lý...';
            btn.disabled = true;

            try {
                const res = await fetch('/giohang/api/dat-hang', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await res.json();

                if (res.ok) {
                    alert('Đặt hàng thành công! Đang chuyển hướng đến trang hướng dẫn thanh toán...');
                    window.location.href = '/phuong-thuc-thanh-toan'; 
                } else {
                    alert('Lỗi: ' + result.loi);
                    btn.innerHTML = '<i class="bi bi-check-circle"></i> XÁC NHẬN ĐẶT HÀNG';
                    btn.disabled = false;
                }
            } catch (error) {
                alert('Lỗi kết nối máy chủ!');
                btn.disabled = false;
            }
        });
    </script>
</body>
</html>