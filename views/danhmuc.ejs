<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <title>Quản lý Danh Mục - PKSoft Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <%- include('style') %>
</head>

<body>
    <%- include('navbar') %>

        <<div class="container my-5">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold"><i class="bi bi-tags-fill me-2"></i>QUẢN LÝ DANH MỤC</h3>
                <a href="/danhmuc/them" class="btn btn-primary shadow-sm fw-bold">
                    <i class="bi bi-plus-circle-fill me-1"></i> Thêm Danh Mục
                </a>
            </div>

            <div class="card shadow-sm border-0">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Tên Danh Mục</th>
                            <th class="text-center">Tổng SP</th>
                            <th class="text-center">SP Đang Hiện</th>
                            <th class="text-center">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% danhMucs.forEach(dm=> { %>
                            <tr>
                                <td class="fw-bold text-primary">
                                    <%= dm.tenDanhMuc %>
                                </td>
                                <td class="text-center"><span class="badge bg-secondary">
                                        <%= dm.tongSanPham %>
                                    </span></td>
                                <td class="text-center"><span class="badge bg-success">
                                        <%= dm.soSanPhamHienThi %>
                                    </span></td>
                                <td class="text-center">
                                    <a href="/danhmuc/sua/<%= dm._id %>" class="btn btn-sm btn-outline-warning">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a href="/danhmuc/xoa/<%= dm._id %>" class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('Bạn có chắc muốn xóa danh mục này?')">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>
            </div>

            <%- include('footer') %>
</body>

</html>