<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= title || 'Thêm Sản Phẩm Mới - Quản Trị' %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <%- include ('style')%>
</head>

<body>
    <%-include ('navbar')%>
        <div class="page-header">
            <div class="container d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="fw-bold mb-0">Thêm Phần Mềm Mới</h2>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0 mt-2">
                            <li class="breadcrumb-item"><a href="/sanpham" class="text-decoration-none text-danger">Quản
                                    lý sản phẩm</a></li>
                            <li class="breadcrumb-item active">Thêm mới</li>
                        </ol>
                    </nav>
                </div>
                <a href="/sanpham" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
            </div>
        </div>

        <div class="container my-5">
            <form id="formThemSanPham">
                <div class="row">
                    <div class="col-lg-8">
                        <div class="admin-card">
                            <h5 class="card-title">Thông tin cơ bản</h5>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Tên phần mềm <span
                                        class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="tenSanPham" required
                                    placeholder="VD: Windows 11 Pro Bản Quyền">
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Mô tả chi tiết</label>
                                <textarea class="form-control" id="moTaChiTiet" rows="5"
                                    placeholder="Nhập mô tả tính năng của phần mềm..."></textarea>
                            </div>

                            <h5 class="card-title mt-4">Cấu hình tối thiểu</h5>
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Hệ điều hành</label>
                                    <input type="text" class="form-control" id="ch_os" placeholder="VD: Windows 10/11">
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">RAM tối thiểu</label>
                                    <input type="text" class="form-control" id="ch_ram" placeholder="VD: 4GB">
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Dung lượng ổ cứng</label>
                                    <input type="text" class="form-control" id="ch_disk" placeholder="VD: 64GB">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="admin-card">
                            <h5 class="card-title">Phân loại & Giá</h5>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Danh mục <span class="text-danger">*</span></label>
                                <select class="form-select" id="danhMuc_id" required>
                                    <option value="" disabled selected>Đang tải danh mục...</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Giá bán (VNĐ) <span
                                        class="text-danger">*</span></label>
                                <input type="number" class="form-control" id="giaBan" required min="0"
                                    placeholder="VD: 500000">
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Giá gốc (VNĐ) <span class="text-muted fw-normal">(Tùy
                                        chọn)</span></label>
                                <input type="number" class="form-control" id="giaGoc" min="0"
                                    placeholder="Để trống nếu không giảm giá">
                            </div>

                            <hr>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Chọn hình ảnh sản phẩm</label>
                                <input type="file" class="form-control mb-2" id="hinhAnh"
                                    accept="image/png, image/jpeg, image/jpg, image/webp">
                                <div class="form-text">Hỗ trợ định dạng: JPG, PNG, WEBP. Dung lượng tối đa 2MB.</div>

                                <div id="previewContainer" class="mt-3 d-none text-center border rounded p-2 bg-light">
                                    <img id="anhXemTruoc" src="" alt="Xem trước"
                                        style="max-height: 150px; max-width: 100%; border-radius: 4px;">
                                </div>
                            </div>

                            <div class="form-check form-switch mb-4 mt-3">
                                <input class="form-check-input" type="checkbox" id="hienThi" checked>
                                <label class="form-check-label fw-bold" for="hienThi">Hiển thị trên Web</label>
                            </div>

                            <button type="submit" class="btn btn-red w-100 py-2 fs-5">
                                <i class="bi bi-save"></i> Lưu Sản Phẩm Mới
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
        <%- include ('footer')%>

            <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
            <script>
                // 1. Hàm tự động lấy danh sách Danh Mục khi trang vừa load
                async function loadDanhSachDanhMuc() {
                    var selectDanhMuc = document.getElementById('danhMuc_id');
                    try {
                        var response = await fetch('/danhmuc/api/danhsach');
                        var danhMucs = await response.json();

                        if (danhMucs.length === 0) {
                            selectDanhMuc.innerHTML = '<option value="" disabled selected>Chưa có danh mục nào trong hệ thống</option>';
                            return;
                        }

                        selectDanhMuc.innerHTML = '<option value="" disabled selected>-- Chọn danh mục --</option>';
                        danhMucs.forEach(dm => {
                            selectDanhMuc.innerHTML += `<option value="${dm._id}">${dm.tenDanhMuc}</option>`;
                        });
                    } catch (error) {
                        console.error("Lỗi khi tải danh mục:", error);
                        selectDanhMuc.innerHTML = '<option value="" disabled selected>Lỗi tải danh mục</option>';
                    }
                }

                document.addEventListener('DOMContentLoaded', loadDanhSachDanhMuc);

                document.getElementById('hinhAnh').addEventListener('change', function (event) {
                    var file = event.target.files[0];
                    var previewContainer = document.getElementById('previewContainer');
                    var anhXemTruoc = document.getElementById('anhXemTruoc');

                    if (file) {
                        var reader = new FileReader();
                        reader.onload = function (e) {
                            anhXemTruoc.src = e.target.result;
                            previewContainer.classList.remove('d-none');
                        }
                        reader.readAsDataURL(file);
                    } else {
                        previewContainer.classList.add('d-none'); 
                    }
                });

                // 3. Xử lý sự kiện Submit Form bằng FormData
                document.getElementById('formThemSanPham').addEventListener('submit', async function (e) {
                    e.preventDefault();

                    var cauHinh = {
                        os: document.getElementById('ch_os').value,
                        ram: document.getElementById('ch_ram').value,
                        disk: document.getElementById('ch_disk').value
                    };

                    var formData = new FormData();
                    formData.append('tenSanPham', document.getElementById('tenSanPham').value);
                    formData.append('danhMuc_id', document.getElementById('danhMuc_id').value);
                    formData.append('moTaChiTiet', document.getElementById('moTaChiTiet').value);
                    formData.append('giaBan', document.getElementById('giaBan').value);

                    var giaGocValue = document.getElementById('giaGoc').value;
                    if (giaGocValue) formData.append('giaGoc', giaGocValue);

                    formData.append('hienThi', document.getElementById('hienThi').checked);

                    // Vì FormData chỉ nhận chuỗi/file, ta biến Object cấu hình thành chuỗi JSON
                    formData.append('cauHinhToiThieu', JSON.stringify(cauHinh));

                    // Nạp file ảnh vào FormData
                    var fileInput = document.getElementById('hinhAnh');
                    if (fileInput.files.length > 0) {
                        formData.append('hinhAnh', fileInput.files[0]);
                    }

                    // Đổi trạng thái nút
                    var btnSubmit = e.target.querySelector('button[type="submit"]');
                    var originalBtnText = btnSubmit.innerHTML;
                    btnSubmit.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Đang tải lên...';
                    btnSubmit.disabled = true;

                    try {
                        var response = await fetch('/sanpham/them', {
                            method: 'POST',
                            body: formData
                        });

                        if (response.ok || response.redirected) {
                            alert('Thêm sản phẩm thành công!');
                            window.location.href = '/sanpham'; 
                        } else {
                            alert('Lỗi: Không thể thêm sản phẩm, vui lòng thử lại!');
                            btnSubmit.innerHTML = originalBtnText;
                            btnSubmit.disabled = false;
                        }
                    } catch (error) {
                        console.error(error);
                        alert('Lỗi kết nối đến máy chủ!');
                        btnSubmit.innerHTML = originalBtnText;
                        btnSubmit.disabled = false;
                    }
                });
            </script>
</body>

</html>