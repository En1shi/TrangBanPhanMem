<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <%- include('style') %>
</head>
<body>
    <%- include('navbar') %>

    <div class="container my-5">
        <h2 class="fw-bold mb-4">Giỏ Hàng Của Bạn</h2>

        <% if (cart.length === 0) { %>
            <div class="text-center cart-container py-5">
                <i class="bi bi-cart-x text-muted" style="font-size: 5rem;"></i>
                <h4 class="mt-3">Giỏ hàng đang trống</h4>
                <p class="text-muted">Có vẻ như bạn chưa chọn mua phần mềm nào.</p>
                <a href="/sanpham/danhsach" class="btn btn-red mt-2">Tiếp tục mua sắm</a>
            </div>
        <% } else { %>
            <div class="row">
                <div class="col-lg-8 mb-4">
                    <div class="cart-container">
                        <table class="table align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Sản Phẩm</th>
                                    <th width="15%">Đơn Giá</th>
                                    <th width="15%" class="text-center">Số Lượng</th>
                                    <th width="15%" class="text-end">Tạm Tính</th>
                                    <th width="5%"></th>
                                </tr>
                            </thead>
                            <tbody>
                                <% cart.forEach(item => { %>
                                    <tr id="row-<%= item.sanPham_id %>">
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <img src="/images/<%= item.hinhAnh %>" class="cart-img me-3" style="max-width: 60px; border-radius: 8px;">
                                                <span class="fw-bold text-dark"><%= item.tenSanPham %></span>
                                            </div>
                                        </td>
                                        <td class="text-danger fw-bold"><%= item.giaBan.toLocaleString('vi-VN') %>đ</td>
                                        <td>
                                            <input type="number" class="form-control text-center input-soluong" 
                                                value="<%= item.soLuong %>" min="1" 
                                                onchange="capNhatGioHang('<%= item.sanPham_id %>', this.value)">
                                        </td>
                                        <td class="text-end fw-bold text-primary">
                                            <%= (item.giaBan * item.soLuong).toLocaleString('vi-VN') %>đ
                                        </td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-outline-danger" onclick="xoaKhoiGio('<%= item.sanPham_id %>')">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="cart-container">
                        <h5 class="fw-bold mb-3 border-bottom pb-2">Tóm Tắt Đơn Hàng</h5>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Tạm tính:</span>
                            <span class="fw-bold"><%= tongTien.toLocaleString('vi-VN') %>đ</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3 text-success">
                            <span>Giảm giá:</span>
                            <span>0đ</span>
                        </div>
                        <div class="d-flex justify-content-between mb-4 border-top pt-3">
                            <span class="fw-bold fs-5">Tổng cộng:</span>
                            <span class="fw-bold fs-4 text-danger"><%= tongTien.toLocaleString('vi-VN') %>đ</span>
                        </div>
                        <a href="/giohang/thanhtoan" class="btn btn-red w-100 py-2 fs-5 fw-bold">
                            Tiến hành thanh toán
                        </a>
                    </div>
                </div>
            </div>
        <% } %>
    </div>

    <%- include('footer') %>
    
    <script>
        // Hàm cập nhật số lượng
        async function capNhatGioHang(idSanPham, soLuongMoi) {
            if(soLuongMoi < 1) return; // Không cho nhập số âm
            
            try {
                const response = await fetch('/giohang/api/cap-nhat', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ sanPham_id: idSanPham, soLuong: soLuongMoi })
                });
                
                if (response.ok) {
                    // Tải lại trang để EJS tự động tính toán lại Tổng tiền và hiển thị
                    window.location.reload(); 
                } else {
                    alert('Lỗi khi cập nhật số lượng!');
                }
            } catch (error) {
                alert('Lỗi kết nối máy chủ!');
            }
        }

        // Hàm xóa khỏi giỏ
        async function xoaKhoiGio(idSanPham) {
            if (confirm('Bạn có chắc chắn muốn xóa phần mềm này khỏi giỏ hàng?')) {
                try {
                    const response = await fetch('/giohang/api/xoa/' + idSanPham, {
                        method: 'DELETE'
                    });
                    
                    if (response.ok) {
                        window.location.reload(); 
                    } else {
                        alert('Lỗi khi xóa sản phẩm!');
                    }
                } catch (error) {
                    alert('Lỗi kết nối máy chủ!');
                }
            }
        }
    </script>
</body>
</html>